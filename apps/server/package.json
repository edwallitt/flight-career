    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@flightcareer/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.0.0-rc.660",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
