{
  "name": "flightcareer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,web -c blue,magenta \"pnpm --filter @flightcareer/server dev\" \"pnpm --filter @flightcareer/web dev\"",
    "build": "pnpm --filter @flightcareer/server typecheck && pnpm --filter @flightcareer/web build",
    "typecheck": "pnpm --filter @flightcareer/server typecheck && pnpm --filter @flightcareer/web exec tsc -b",
    "test": "pnpm --filter @flightcareer/shared test && pnpm --filter @flightcareer/server test && pnpm --filter @flightcareer/web test",
    "db:generate": "pnpm --filter @flightcareer/server db:generate",
    "db:migrate": "pnpm --filter @flightcareer/server db:migrate",
    "dev:audit-listings": "pnpm --filter @flightcareer/server audit-listings"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0"
}
